      "proxy_url": "http://127.0.0.1:7890",
      "allow_direct": true,
      "allow_proxy_fallback": true,
      "source_fields": [
        "response"
      ],
      "enable_domain_intel": true,
      "use_dns_resolver": false,
      "use_rdap": false,
      "rdap_timeout_sec": 4.0
    },
    "dns_enriched": {
