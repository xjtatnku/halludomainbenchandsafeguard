  "notes": "Stage validation evidence gradually. Use baseline_http while the truth store is still expanding, dns_enriched when official/authorized coverage is stable, and rdap_curated after the high-risk truth set has been manually reviewed.",
  "profiles": {
    "baseline_http": {
      "concurrency_limit": 80,
      "request_timeout_sec": 12.0,
