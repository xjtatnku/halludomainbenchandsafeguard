    "scored_responses": "data/experiments/ablation_kimi_mode/response/scored_links.jsonl",
    "legacy_verification_report_csv": "data/experiments/ablation_kimi_mode/response/verification_report.csv",
    "legacy_dead_links_csv": "data/experiments/ablation_kimi_mode/response/verification_report_dead.csv",
    "candidate_report_csv": "data/experiments/ablation_kimi_mode/reports/candidate_report.csv",
    "response_report_csv": "data/experiments/ablation_kimi_mode/reports/response_report.csv",
    "summary_by_model_csv": "data/experiments/ablation_kimi_mode/reports/model_summary.csv",
    "summary_by_domain_csv": "data/experiments/ablation_kimi_mode/reports/domain_summary.csv",
